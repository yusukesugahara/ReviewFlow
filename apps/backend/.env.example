# ReviewFlow backend local environment example.
#
# ローカル開発: このファイルを `.env` または `.env.dev` にコピーして使う
# （`NODE_ENV !== production` のとき `AppModule` は `.env` のあと `.env.dev` を読み込む）
NODE_ENV=development

PORT=3000

# Next.js サーバー → Nest API（共有秘密。NEXT_PUBLIC_ にしない）
# apps/frontend/.env.example の INTERNAL_API_KEY と同じ値にする。
INTERNAL_API_KEY=dev-internal-key-change-me

# Nest が署名・検証に使う秘密鍵（十分に長いランダム文字列）
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# SQLite はローカル開発・テスト用。production 想定 DB は MySQL。
# DB_DRIVER=sqlite（省略時）| mysql | mariadb
DB_PATH=var/sqlite.db

# MySQL / MariaDB 利用時（DB_DRIVER=mysql または mariadb）。DATABASE_URL があれば個別の DB_* は不要。
# DB_DRIVER=mysql
# DATABASE_URL=mysql://app:app@localhost:3306/app
# DB_HOST=localhost
# DB_PORT=3306
# DB_USERNAME=app
# DB_PASSWORD=app
# DB_NAME=app
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true

# `false` のときスキーマ自動同期をオフにし、起動時にマイグレーションを実行する（本番は NODE_ENV=production で常にこの挙動）
# DB_SYNCHRONIZE=false

# レート制限（@nestjs/throttler）。本番の既定は 60 秒あたり 120 リクエスト（IP 単位）。開発は緩め。
# THROTTLE_TTL_MS=60000
# THROTTLE_LIMIT=120
# THROTTLE_LIMIT_DEV=2000

# リバースプロキシ背後で Nest がクライアント IP を正しく扱う（レート制限・ログ用）。1 のとき trust proxy を有効化
# TRUST_PROXY=1

# JSON / urlencoded の最大サイズ（例: 256kb, 1mb）
# JSON_BODY_LIMIT=256kb

# メール送信設定
# `NODE_ENV=production` では MAIL_PROVIDER=smtp を推奨。
# テスト・検証用途で Gmail を使う場合は MAIL_PROVIDER=gmail と Gmail App Password を設定する。
# MAIL_ENABLED=1
# MAIL_PROVIDER=gmail
# MAIL_FROM=ReviewFlow <no-reply@example.com>
# MAIL_REPLY_TO=support@example.com
# FRONTEND_BASE_URL=http://localhost:3001

# Gmail 用（テスト・検証向け）
# MAIL_GMAIL_USER=example@gmail.com
# MAIL_GMAIL_APP_PASSWORD=your-app-password

# SMTP 用（本番向け）
# MAIL_PROVIDER=smtp
# MAIL_SMTP_HOST=smtp.example.com
# MAIL_SMTP_PORT=587
# MAIL_SMTP_SECURE=false
# MAIL_SMTP_USER=smtp-user
# MAIL_SMTP_PASSWORD=smtp-password

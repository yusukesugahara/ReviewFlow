# ローカル開発: このファイルを `.env` または `.env.dev` にコピーして使う
# （`NODE_ENV !== production` のとき `AppModule` は `.env` のあと `.env.dev` を読み込む）
NODE_ENV=development

PORT=3000

# Next.js サーバー → 本 API（共有秘密。NEXT_PUBLIC_ にしない）
INTERNAL_API_KEY=dev-internal-key-change-me

# Nest が署名・検証に使う秘密鍵（十分に長いランダム文字列）
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# DB_DRIVER=sqlite（省略時）| mysql | mariadb
DB_PATH=var/sqlite.db

# MySQL / MariaDB 利用時（DB_DRIVER=mysql または mariadb）。DATABASE_URL があれば個別の DB_* は不要。
# DB_DRIVER=mysql
# DATABASE_URL=mysql://app:app@localhost:3306/app
# DB_HOST=localhost
# DB_PORT=3306
# DB_USERNAME=app
# DB_PASSWORD=app
# DB_NAME=app
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true

# `false` のときスキーマ自動同期をオフにし、起動時にマイグレーションを実行する（本番は NODE_ENV=production で常にこの挙動）
# DB_SYNCHRONIZE=false

# レート制限（@nestjs/throttler）。本番の既定は 60 秒あたり 120 リクエスト（IP 単位）。開発は緩め。
# THROTTLE_TTL_MS=60000
# THROTTLE_LIMIT=120
# THROTTLE_LIMIT_DEV=2000

# リバースプロキシ背後で Nest がクライアント IP を正しく扱う（レート制限・ログ用）。1 のとき trust proxy を有効化
# TRUST_PROXY=1

# JSON / urlencoded の最大サイズ（例: 256kb, 1mb）
# JSON_BODY_LIMIT=256kb

              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "status",
                    "data"
                  ],
                  "properties": {
                    "status": {
                      "type": "number",
                      "enum": [
                        200
                      ],
                      "example": 200
                    },
                    "data": {
                      "$ref": "#/components/schemas/AuthIssueTokensResponseDto"
                    }
                  }
                }
              }
            }
          },
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "status",
                    "data"
                  ],
                  "properties": {
                    "status": {
                      "type": "number",
                      "enum": [
                        200
                      ],
                      "example": 200
                    },

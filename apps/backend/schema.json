        ]
      }
    },
    "/auth/admin/ping": {
      "get": {
        "operationId": "AuthController_adminPing",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "status",
                    "data"
                  ],
                  "properties": {
                    "status": {
                      "type": "number",
                      "enum": [
                        200
                      ],
                      "example": 200

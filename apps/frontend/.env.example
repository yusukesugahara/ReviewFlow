# ReviewFlow frontend local environment example.
#
# 利用可能なキー一覧・既定値は src/lib/env.ts を参照
#
# ブラウザからも参照される API のオリジン（末尾スラッシュなし推奨）
NEXT_PUBLIC_API_URL=http://127.0.0.1:3000

# サーバー専用（Server Action / Route Handler から Nest へ X-API-Key で送る）。NEXT_PUBLIC にしないこと。
# バックエンドの INTERNAL_API_KEY と同一の値にする。
INTERNAL_API_KEY=dev-internal-key-change-me

# 任意。Docker Compose 等でブラウザ向けは localhost、Next.js サーバーからはサービス名で届けるときに設定。
# INTERNAL_API_ORIGIN=http://backend:3000
